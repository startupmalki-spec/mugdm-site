# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic AI (required for document analysis)
ANTHROPIC_API_KEY=

# Resend (required for transactional emails)
RESEND_API_KEY=

# Stripe (required for subscription billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_BUSINESS_MONTHLY_PRICE_ID=
STRIPE_BUSINESS_ANNUAL_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_ANNUAL_PRICE_ID=
NEXT_PUBLIC_STRIPE_BUSINESS_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_BUSINESS_ANNUAL_PRICE_ID=

# PostHog Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Wathq API (required for CR verification)
WATHQ_API_KEY=
WATHQ_API_SECRET=
# Optional: override the Wathq base URL list (comma-separated). Leave blank to
# use defaults (prod + trial + apidev). Set to a single URL to pin one.
# WATHQ_BASE_URLS=https://api.wathq.sa/v5

# Cron secret (required for scheduled notification endpoint)
CRON_SECRET=

# Feature flags
NEXT_PUBLIC_FEATURE_BILLS=true
