# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic AI (required for document analysis)
ANTHROPIC_API_KEY=

# Resend (required for transactional emails)
RESEND_API_KEY=

# Stripe (required for subscription billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_BUSINESS_MONTHLY_PRICE_ID=
STRIPE_BUSINESS_ANNUAL_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_ANNUAL_PRICE_ID=
NEXT_PUBLIC_STRIPE_BUSINESS_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_BUSINESS_ANNUAL_PRICE_ID=

# PostHog Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Cron secret (required for scheduled notification endpoint)
CRON_SECRET=

# Wathq (Saudi MoC) Commercial Registration API
# Used to look up verified business data by CR number during onboarding and
# customer creation. When unset, the app falls back to OCR + QR scraping and
# the customer form's Wathq button returns a graceful error. Request a key
# at https://developer.wathq.sa.
WATHQ_API_KEY=

# ZATCA Fatoora e-invoicing
ZATCA_ENV=sandbox  # 'sandbox' or 'production'
ZATCA_CERT_ENCRYPTION_KEY=  # 32-byte key (hex/base64) for encrypting stored CSID private keys at rest
